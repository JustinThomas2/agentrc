#!/bin/bash
# Global pre-push (core.hooksPath = ~/.githooks).

# Buffer the pushed-refs list git sends on stdin, so it can be checked here
# AND replayed to a chained repo hook (reading stdin twice is impossible).
input=$(cat)

# Block Claude Code from pushing to main/master.
if [ "$CLAUDECODE" = "1" ]; then
  while read local_ref local_sha remote_ref remote_sha; do
    TARGET=$(echo "$remote_ref" | sed 's#refs/heads/##')
    if [ "$TARGET" = "main" ] || [ "$TARGET" = "master" ]; then
      echo "Claude Code cannot push to '$TARGET'." >&2
      exit 1
    fi
  done <<< "$input"
fi

# Chain to the repo's own hook if it has one — git runs exactly one
# hooksPath, so without this a global path silences .git/hooks/pre-push.
repo_hook="$(git rev-parse --git-dir)/hooks/pre-push"
if [ -x "$repo_hook" ]; then
  printf '%s\n' "$input" | "$repo_hook" "$@"
  exit $?
fi
exit 0
