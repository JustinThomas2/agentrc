{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git rev-list:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*credentials*)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.kube/**)",
      "Bash(rm -rf:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh auth token:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh workflow run:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git tag -d:*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DELETE FROM*)"
    ],
    "ask": [
      "Edit(.github/**)",
      "Write(.github/**)",
      "Edit(**/Dockerfile*)",
      "Write(**/Dockerfile*)",
      "Edit(**/docker-compose*.yml)",
      "Write(**/docker-compose*.yml)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(pnpm add:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(aws:*)",
      "Bash(gcloud:*)",
      "WebFetch"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/gh-pin-repo.py"
          }
        ]
      }
    ]
  },
  "theme": "dark",
  "model": "claude-fable-5[1m]"
}
